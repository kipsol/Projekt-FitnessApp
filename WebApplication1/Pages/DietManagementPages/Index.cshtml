@page
@model WebApplication1.Pages.DietPages.DietManagementIndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Diet[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Diet[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Diet[0].TargetCalories)
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Diet) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.Name)
            </td>
            <td>
                @Html.DisplayFor(model => item.Description)
            </td>
            <td>
                @Html.DisplayFor(model => item.TargetCalories)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
