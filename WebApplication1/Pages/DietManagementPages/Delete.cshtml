@page
@model WebApplication1.Pages.DietManagementPages.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Usuwanie Diety</h1>

<h3>Czy na pewno chcesz to usunąć?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Diet.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Diet.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Diet.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Diet.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Diet.TargetCalories)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Diet.TargetCalories)
        </dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="Diet.Id" />
        <input type="submit" value="Usuń" class="btn btn-danger" /> |
        <a asp-page="/DietPages/Index">Powrót</a>
    </form>
</div>
