@page
@model WebApplication1.Pages.ClassEventPages.IndexModel

@{
    ViewData["Title"] = "Baza Zajęć";
}

<style>
    .dark-table-container {
        background-color: #1a1a1a;
        border-radius: 12px;
        border: 1px solid #333;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.5);
    }

    .dark-table {
        width: 100%;
        margin-bottom: 0;
        color: #cfcfcf;
    }

        .dark-table thead {
            background-color: #222;
            border-bottom: 3px solid #8a2be2;
        }

        .dark-table th {
            padding: 18px;
            color: #fff;
            font-weight: 600;
            border: none;
        }

        .dark-table td {
            padding: 18px;
            vertical-align: middle;
            border-bottom: 1px solid #2a2a2a;
        }

        .dark-table tr:hover {
            background-color: #252525;
        }

    .action-btn {
        color: #aaa;
        text-decoration: none;
        padding: 6px 12px;
        border: 1px solid #444;
        border-radius: 6px;
        margin-right: 5px;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }

        .action-btn:hover {
            color: #b052ff;
            border-color: #8a2be2;
            background-color: rgba(138,43,226,0.1);
        }

    .action-delete:hover {
        color: #fff;
        border-color: #ff4d4d;
        background-color: rgba(255, 77, 77, 0.8);
    }

    .btn-neon {
        background-color: #8a2be2;
        color: #fff;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
        border: none;
    }

        .btn-neon:hover {
            background-color: #9d4edd;
            color: #fff;
            box-shadow: 0 0 15px rgba(138,43,226,0.4);
        }

    .btn-outline-dark-theme {
        border: 1px solid #555;
        color: #ccc;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: bold;
        transition: 0.3s;
    }

        .btn-outline-dark-theme:hover {
            background-color: #333;
            color: #fff;
            border-color: #777;
        }
</style>

