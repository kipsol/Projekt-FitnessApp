@page
@model WebApplication1.Pages.OrderItemPages.DeleteModel

@{
    ViewData["Title"] = "Usuń pozycję zamówienia";
}

<h1>Usuń pozycję zamówienia</h1>
<h3>Czy na pewno chcesz usunąć tę pozycję?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.OrderItem.OrderId)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OrderItem.OrderId)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.OrderItem.ProductId)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OrderItem.ProductId)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.OrderItem.Quantity)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OrderItem.Quantity)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.OrderItem.PriceAtPurchase)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.OrderItem.PriceAtPurchase)</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="OrderItem.Id" />
        <input type="submit" value="Usuń" class="btn btn-danger" /> |
        <a asp-page="./Index">Powrót do listy</a>
    </form>
</div>
