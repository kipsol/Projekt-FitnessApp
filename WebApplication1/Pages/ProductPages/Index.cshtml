@page
@model WebApplication1.Pages.ProductPages.IndexModel

@{
    ViewData["Title"] = "Magazyn Produktów";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-light fw-bold">Produkty</h2>
            <p class="text-muted small">Kupuj, dźwigaj, ROŚNIJ!</p>
        </div>
        @if (Model.CanManageStore)
        {
            <a asp-page="Create" class="btn btn-primary shadow-sm" style="background-color: #8a2be2; border: none;">➕ Dodaj nowy produkt</a>
        }
    </div>

    <div class="card shadow-sm border-0" style="background-color: #1a1a1a; border: 1px solid #333;">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0 text-light">
                <thead style="background-color: #222; border-bottom: 3px solid #8a2be2;">
                    <tr>
                        <th class="ps-4">Nazwa produktu</th>
                        <th>Opis</th>
                        <th class="text-end">Cena brutto</th>
                        <th class="text-center">Stan magazynowy</th>
                        <th class="text-center">Kategoria</th>
                        <th class="text-end pe-4">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Product)
                    {
                        <tr style="border-bottom: 1px solid #2a2a2a;">
                            <td class="fw-bold ps-4" style="color: #b052ff;">@item.Name</td>

                            <td class="text-muted small" style="max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @item.Description
                            </td>

                            <td class="text-end fw-bold text-success">@item.Price.ToString("F2") PLN</td>

                            <td class="text-center">
                                @if (item.Stock == 0)
                                {
                                    <span class="badge bg-danger">Brak na stanie</span>
                                }
                                else if (item.Stock < 5)
                                {
                                    <span class="badge bg-warning text-dark">@item.Stock szt. (Kończy się)</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.Stock szt.</span>
                                }
                            </td>

                            <td class="text-center">
                                <span class="badge" style="background-color: #333; color: #ccc;">@item.Category</span>
                            </td>

                            <td class="text-end pe-4">
                                @if (Model.CanManageStore)
                                {
                                    <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary me-1">Edytuj</a>
                                }
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1">Szczegóły</a>
                                <a asp-page="/OrderPages/Create" asp-route-productId="@item.Id" class="btn btn-sm btn-outline-success me-1">Zamów</a>
                                @if (Model.CanManageStore)
                                {
                                    <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
