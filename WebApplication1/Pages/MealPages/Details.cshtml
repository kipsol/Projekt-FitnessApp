@page
@model WebApplication1.Pages.MealPages.DetailsModel

@{
    ViewData["Title"] = "Szczegóły Posiłku";
}

<h1>Szczegóły</h1>
<div>
    <h4>Posiłek</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Meal.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Meal.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Meal.Calories)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Meal.Calories)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Meal.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Meal.Description)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Meal.Id" class="btn btn-primary">Edytuj</a> |
    <a asp-page="./Index">Powrót do listy</a>
</div>
