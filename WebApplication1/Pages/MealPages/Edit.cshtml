@page
@model WebApplication1.Pages.MealPages.EditModel

@{
    ViewData["Title"] = "Edycja Posiłku";
}

<h1>Edytuj posiłek</h1>
<h4>Modyfikacja bazy potraw</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Meal.Id" />

            <div class="form-group mb-3">
                <label asp-for="Meal.Name" class="control-label"></label>
                <input asp-for="Meal.Name" class="form-control" />
                <span asp-validation-for="Meal.Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Meal.Calories" class="control-label"></label>
                <input asp-for="Meal.Calories" class="form-control" />
                <span asp-validation-for="Meal.Calories" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Meal.Description" class="control-label"></label>
                <input asp-for="Meal.Description" class="form-control" />
                <span asp-validation-for="Meal.Description" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Zapisz zmiany" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-page="./Index">Powrót do listy</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
