@page
@model IndexModel
@{
    ViewData["Title"] = "Progres";
}

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 align-items-md-center mb-4">
    <div>
        <h1 class="h2 mb-1">Progres</h1>
        <p class="text-muted mb-0">Pomiary i notatki do sledzenia zmian.</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <form method="post" class="border rounded-2 p-4 bg-light">
            <h2 class="h5 mb-3">Dodaj wpis</h2>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Input.EntryDate" class="form-label"></label>
                <input asp-for="Input.EntryDate" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
                <span asp-validation-for="Input.EntryDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.WeightKg" class="form-label"></label>
                <input asp-for="Input.WeightKg" class="form-control" step="0.1" />
                <span asp-validation-for="Input.WeightKg" class="text-danger"></span>
            </div>

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Input.ChestCm" class="form-label"></label>
                    <input asp-for="Input.ChestCm" class="form-control" step="0.1" />
                    <span asp-validation-for="Input.ChestCm" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.WaistCm" class="form-label"></label>
                    <input asp-for="Input.WaistCm" class="form-control" step="0.1" />
                    <span asp-validation-for="Input.WaistCm" class="text-danger"></span>
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.HipCm" class="form-label"></label>
                    <input asp-for="Input.HipCm" class="form-control" step="0.1" />
                    <span asp-validation-for="Input.HipCm" class="text-danger"></span>
                </div>
            </div>

            <div class="mt-3 mb-3">
                <label asp-for="Input.Notes" class="form-label"></label>
                <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Input.Notes" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Dodaj</button>
        </form>
    </div>

    <div class="col-lg-8">
        <div class="table-responsive border rounded-2">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>Data</th>
                        <th>Waga</th>
                        <th>Klatka</th>
                        <th>Talia</th>
                        <th>Biodra</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Entries.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-muted">Brak wpisow progresu.</td>
                    </tr>
                }
                else
                {
                    @foreach (var entry in Model.Entries)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@entry.EntryDate.ToString("yyyy-MM-dd")</div>
                                @if (!string.IsNullOrWhiteSpace(entry.Notes))
                                {
                                    <div class="small text-muted">@entry.Notes</div>
                                }
                            </td>
                            <td>@entry.WeightKg kg</td>
                            <td>@(entry.ChestCm.HasValue ? $"{entry.ChestCm} cm" : "-")</td>
                            <td>@(entry.WaistCm.HasValue ? $"{entry.WaistCm} cm" : "-")</td>
                            <td>@(entry.HipCm.HasValue ? $"{entry.HipCm} cm" : "-")</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="Delete" asp-route-id="@entry.Id">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Usun</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
