@page
@model WebApplication1.Pages.ClassSchedulePages.IndexModel
@{
    ViewData["Title"] = "Grafik Zajęć";

    var dniPoPolsku = new Dictionary<DayOfWeek, string>
    {
        { DayOfWeek.Monday, "Poniedziałek" },
        { DayOfWeek.Tuesday, "Wtorek" },
        { DayOfWeek.Wednesday, "Środa" },
        { DayOfWeek.Thursday, "Czwartek" },
        { DayOfWeek.Friday, "Piątek" },
        { DayOfWeek.Saturday, "Sobota" },
        { DayOfWeek.Sunday, "Niedziela" }
    };
}

<style>
    .theme-card {
        background-color: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    }

    .btn-neon {
        background-color: #8a2be2;
        color: #fff;
        border: none;
        transition: 0.3s ease;
    }

        .btn-neon:hover {
            background-color: #9d4edd;
            color: #fff;
            box-shadow: 0 0 15px rgba(138,43,226,0.5);
        }

    .btn-outline-neon {
        border: 2px solid #8a2be2;
        color: #b052ff;
        background-color: transparent;
        transition: 0.3s ease;
    }

        .btn-outline-neon:hover {
            background-color: #8a2be2;
            color: #fff;
        }

    .day-box {
        background-color: #1a1a1a;
        border: 1px solid #333;
        border-top: 4px solid #8a2be2;
        border-radius: 10px;
        padding: 20px 15px;
        height: 100%;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: flex;
        flex-direction: column;
    }

        .day-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(138,43,226,0.15);
            border-color: #555;
        }

    .class-item {
        background-color: #222;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 12px;
        border-left: 4px solid #b052ff;
        box-shadow: 0 4px 10px rgba(0,0,0,0.3);
        transition: background-color 0.2s ease;
        position: relative;
    }

        .class-item:hover {
            background-color: #2a2a2a;
        }

    .class-time {
        color: #b052ff;
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 3px;
    }

    .class-name {
        color: #fff;
        font-weight: 600;
        font-size: 1.05rem;
        line-height: 1.2;
        margin-bottom: 6px;
        padding-right: 25px;
    }

    .class-trainer {
        color: #aaa;
        font-size: 0.8rem;
    }

    .delete-class-btn {
        color: #ff4d4d;
        font-size: 1.1rem;
        background: none;
        border: none;
        padding: 0;
        transition: 0.2s ease;
        opacity: 0.6;
        position: absolute;
        top: 8px;
        right: 12px;
    }

        .delete-class-btn:hover {
            color: #ff8080;
            opacity: 1;
            transform: scale(1.1);
        }
</style>

<div class="container mt-4">
    <div class="theme-card p-4 mb-5 d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h2 class="text-light fw-bold mb-1">📅 Twój Grafik Zajęć Fitness</h2>
            <p class="text-muted mb-0 small">Zarządzaj swoimi rezerwacjami treningów grupowych</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a asp-page="/ClassEventPages/Index" class="btn btn-outline-neon fw-bold px-4 py-2">
                ⚙️ Zarządzaj bazą
            </a>
            <a asp-page="./Create" class="btn btn-neon fw-bold px-4 py-2 shadow-sm">
                ➕ Zapisz się na zajęcia
            </a>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4 mb-5">
        @foreach (var dzien in dniPoPolsku)
        {
            var zajeciaNaTenDzien = Model.GrafikTygodniowy[dzien.Key];

            <div class="col">
                <div class="day-box">
                    <h5 class="text-center mb-4 fw-bold" style="color: #b052ff; letter-spacing: 0.5px;">@dzien.Value</h5>

                    <div class="flex-grow-1">
                        @if (!zajeciaNaTenDzien.Any())
                        {
                            <div class="text-center text-muted small mt-2" style="font-style: italic;">
                                Brak zaplanowanych zajęć.
                            </div>
                        }
                        else
                        {
                            foreach (var wpis in zajeciaNaTenDzien)
                            {
                                <div class="class-item">
                                    <form method="post" asp-page-handler="DeleteFromSchedule" asp-route-scheduleId="@wpis.Id"
                                          onsubmit="return confirm('Czy na pewno chcesz wypisać się z tych zajęć?');">
                                        <button type="submit" class="delete-class-btn" title="Wypisz się">✖</button>
                                    </form>

                                    <div class="class-time">
                                        🕒 @wpis.ClassEvent?.StartTime.ToString(@"hh\:mm")
                                    </div>
                                    <div class="class-name">
                                        @wpis.ClassEvent?.Name
                                    </div>
                                    <div class="class-trainer">
                                        👤 Prowadzący: @wpis.ClassEvent?.Trainer
                                    </div>
                                    <div class="mt-3">
                                        <span class="badge" style="background-color: #333; color: #ccc; border: 1px solid #444; font-size: 0.75rem;">
                                            ⏳ @wpis.ClassEvent?.Duration min
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>