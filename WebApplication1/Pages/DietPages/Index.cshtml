@page
@model WebApplication1.Pages.DietPages.IndexModel

@{
    ViewData["Title"] = "Moje Diety";

    var dniTygodnia = new Dictionary<string, DayOfWeek>
    {
        {"Poniedziałek", DayOfWeek.Monday},
        {"Wtorek", DayOfWeek.Tuesday},
        {"Środa", DayOfWeek.Wednesday},
        {"Czwartek", DayOfWeek.Thursday},
        {"Piątek", DayOfWeek.Friday},
        {"Sobota", DayOfWeek.Saturday},
        {"Niedziela", DayOfWeek.Sunday}
    };
}

<style>
    .theme-card {
        background-color: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.5);
    }

    .theme-input {
        background-color: #252525;
        color: #e0e0e0;
        border: 1px solid #444;
    }

        .theme-input:focus {
            border-color: #8a2be2;
            box-shadow: 0 0 0 0.25rem rgba(138,43,226,0.25);
            background-color: #2a2a2a;
            color: #fff;
        }

    .btn-neon {
        background-color: #8a2be2;
        color: #fff;
        border: none;
        transition: 0.3s ease;
    }

        .btn-neon:hover {
            background-color: #9d4edd;
            color: #fff;
            box-shadow: 0 0 15px rgba(138,43,226,0.5);
        }

    .btn-outline-neon {
        border: 2px solid #8a2be2;
        color: #b052ff;
        background-color: transparent;
        transition: 0.3s ease;
    }

        .btn-outline-neon:hover {
            background-color: #8a2be2;
            color: #fff;
        }

    .btn-outline-danger-dark {
        border: 1px solid #ff4d4d;
        color: #ff4d4d;
        background-color: transparent;
        transition: 0.3s ease;
    }

        .btn-outline-danger-dark:hover {
            background-color: #ff4d4d;
            color: #fff;
        }

    .day-box {
        background-color: #1a1a1a;
        border: 1px solid #333;
        border-top: 4px solid #8a2be2;
        border-radius: 10px;
        padding: 15px;
        height: 100%;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        display: flex;
        flex-direction: column;
    }

        .day-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(138,43,226,0.15);
            border-color: #555;
        }

    .meal-item {
        background-color: #222;
        border-radius: 6px;
        padding: 8px;
        margin-bottom: 8px;
        border-left: 3px solid #b052ff;
    }

    .meal-name {
        color: #e0e0e0;
        font-weight: 600;
        font-size: 0.85rem;
        display: block;
        line-height: 1.2;
    }

    .meal-kcal {
        color: #aaa;
        font-size: 0.75rem;
    }

    .delete-meal-btn {
        color: #ff4d4d;
        font-size: 0.75rem;
        text-decoration: none;
        padding: 0;
        border: none;
        background: none;
        transition: 0.2s;
    }

        .delete-meal-btn:hover {
            color: #ff8080;
            text-decoration: underline;
        }

    .target-badge {
        background-color: rgba(138,43,226,0.15);
        border: 1px solid #8a2be2;
        color: #b052ff;
        font-weight: 800;
        font-size: 1.2rem;
    }
</style>

<div class="theme-card p-4 mb-5">
    <form method="get" class="row align-items-end g-3">
        <div class="col-md-8">
            <label class="form-label text-muted fw-bold">Wybierz plan diety:</label>
            <select name="id" asp-for="WybraneDietId" class="form-select form-select-lg theme-input" onchange="this.form.submit()" asp-items="Model.WszystkieDiety">
                <option value="">-- Wybierz swój plan --</option>
            </select>
        </div>
        <div class="col-md-4 text-md-end">
            @if (Model.Dieta != null)
            {
                <div class="d-inline-block px-4 py-2 rounded-3 target-badge shadow-sm mb-2">
                    Cel: @Model.Dieta.TargetCalories kcal
                </div>
            }
        </div>
    </form>

    @if (Model.Dieta != null && !string.IsNullOrEmpty(Model.Dieta.Description))
    {
        <div class="mt-4 p-3 rounded shadow-sm" style="background-color: #111; border: 1px solid #222; border-left: 4px solid #8a2be2;">
            <span class="text-light"><strong>Opis planu:</strong> <span class="text-muted">@Model.Dieta.Description</span></span>
        </div>
    }

    <hr style="border-color: #333; margin: 25px 0;" />

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div class="d-flex gap-2 flex-wrap">
            <a asp-page="/DietManagementPages/Create" class="btn btn-outline-neon fw-bold px-4 py-2">➕ Nowa dieta</a>

            @if (Model.Dieta != null)
            {
                <a asp-page="/DietManagementPages/Delete" asp-route-id="@Model.Dieta.Id" class="btn btn-outline-danger-dark fw-bold px-4 py-2">🗑️ Usuń plan</a>
            }
        </div>

        @if (Model.Dieta != null)
        {
            <a asp-page="/DietPlanPages/Create" asp-route-dietId="@Model.Dieta.Id" class="btn btn-neon fw-bold px-4 py-2 shadow-sm">
                ➕ Zaplanuj posiłek
            </a>
        }
    </div>
</div>

@if (Model.Dieta != null)
{
    <h3 class="mb-4 text-light fw-bold border-bottom pb-3" style="border-color: #333 !important;">📅 Twój Plan Tygodniowy</h3>

        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-7 g-3 mb-5">
            @foreach (var dzienKvp in dniTygodnia)
            {
                var nazwaDnia = dzienKvp.Key;
                var EnumDnia = dzienKvp.Value;

                var posilkiWdniu = Model.PosiłkiNaDni.ContainsKey(EnumDnia) ? Model.PosiłkiNaDni[EnumDnia] : new List<WebApplication1.Models.DietPlanDay>();
                var sumaKcal = posilkiWdniu.Sum(p => p.Meal?.Calories ?? 0);

                <div class="col">
                    <div class="day-box">
                        <h5 class="text-center mb-3 fw-bold" style="color: #b052ff; letter-spacing: 0.5px;">@nazwaDnia</h5>

                        <div class="flex-grow-1 mb-3">
                            @if (!posilkiWdniu.Any())
                            {
                                <div class="text-center text-muted small mt-4" style="font-style: italic;">
                                    Brak zaplanowanych posiłków.
                                </div>
                            }
                            else
                            {
                                @foreach (var posilek in posilkiWdniu)
                                {
                                    <div class="meal-item">
                                        <span class="meal-name">@posilek.Meal?.Name</span>
                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <span class="meal-kcal">@posilek.Meal?.Calories kcal</span>

                                            <form method="post" asp-page-handler="DeleteMeal">
                                                <input type="hidden" name="planDayId" value="@posilek.Id" />
                                                <input type="hidden" name="currentDietId" value="@Model.Dieta.Id" />
                                                <button type="submit" class="delete-meal-btn">Usuń</button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <div class="mt-auto border-top pt-3 d-flex justify-content-between align-items-center" style="border-color: #333 !important;">
                            <span class="text-secondary fw-bold" style="font-size: 0.85rem;">Suma:</span>
                            <span class="badge @(sumaKcal > Model.Dieta.TargetCalories ? "bg-danger" : "bg-dark")" style="color: #ccc; font-size: 0.85rem; border: 1px solid #444;">
                                @sumaKcal / @Model.Dieta.TargetCalories
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>