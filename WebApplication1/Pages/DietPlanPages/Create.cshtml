@page
@model WebApplication1.Pages.DietPlanPages.CreateModel
@{
    ViewData["Title"] = "Zaplanuj Posiłek";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 shadow p-4 bg-white rounded">
            <h2 class="mb-4 text-primary text-center">Dodaj posiłek do jadłospisu</h2>
            <hr />

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="form-group mb-3">
                    <label class="form-label fw-bold">Wybierz Plan Diety</label>
                    <select asp-for="Input.DietId" class="form-select form-select-lg" asp-items="Model.DietyLista"></select>
                    <span asp-validation-for="Input.DietId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label fw-bold">Dzień Tygodnia</label>
                    <select asp-for="Input.Day" class="form-select form-select-lg">
                        <option value="Monday">Poniedziałek</option>
                        <option value="Tuesday">Wtorek</option>
                        <option value="Wednesday">Środa</option>
                        <option value="Thursday">Czwartek</option>
                        <option value="Friday">Piątek</option>
                        <option value="Saturday">Sobota</option>
                        <option value="Sunday">Niedziela</option>
                    </select>
                    <span asp-validation-for="Input.Day" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="form-label fw-bold">Typ Posiłku (np. Śniadanie, Obiad)</label>
                    <input asp-for="Input.MealType" class="form-control form-control-lg" placeholder="np. Drugie śniadanie" />
                    <span asp-validation-for="Input.MealType" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label fw-bold">Wybierz Posiłek z bazy</label>
                    <select asp-for="Input.MealId" class="form-select form-select-lg" asp-items="Model.PosilkiLista"></select>
                    <span asp-validation-for="Input.MealId" class="text-danger"></span>
                </div>

                <div class="d-grid gap-2">
                    <input type="submit" value="Zapisz w kalendarzu" class="btn btn-success btn-lg" />
                    <a class="btn btn-outline-secondary" asp-page="/DietPages/Index">Anuluj i wróć</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
