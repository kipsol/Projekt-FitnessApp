@page
@model WebApplication1.Pages.MuscleGroups.EditModel

@{
    ViewData["Title"] = "Edytuj partie miesniowa";
}

<h1>Edytuj partie miesniowa</h1>

<form method="post" class="col-md-6">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="PartiaMiesniowa.Id" />

    <div class="form-group mb-3">
        <label asp-for="PartiaMiesniowa.Nazwa"></label>
        <input asp-for="PartiaMiesniowa.Nazwa" class="form-control" />
        <span asp-validation-for="PartiaMiesniowa.Nazwa" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Zapisz</button>
    <a asp-page="./Index" class="btn btn-link">Powrot</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
